# Copy to .env — run: npx shopify hydrogen env pull
# Never commit .env to git

PUBLIC_STOREFRONT_ID=
PUBLIC_STOREFRONT_API_TOKEN=
PUBLIC_STORE_DOMAIN=your-store.myshopify.com
PUBLIC_CHECKOUT_DOMAIN=your-store.myshopify.com
PRIVATE_STOREFRONT_API_TOKEN=
PUBLIC_CUSTOMER_ACCOUNT_API_CLIENT_ID=
PUBLIC_CUSTOMER_ACCOUNT_API_URL=
SHOP_ID=
SESSION_SECRET=

# Didit KYC (server-side only — never commit real values)
DIDIT_API_KEY=
DIDIT_WEBHOOK_SECRET=

# Shopify Admin API (custom app: read_customers + write_customers)
SHOPIFY_ADMIN_API_ACCESS_TOKEN=

# Shared secret for checkout UI extension → Oxygen API calls
CHECKOUT_EXTENSION_SECRET=

# Public Oxygen URL (webhook registration, extension settings)
PUBLIC_STOREFRONT_ORIGIN=
